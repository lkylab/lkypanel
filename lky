# ── ssl commands ──────────────────────────────────────────────────────────────
def cmd_ssl_request(args):
    _require_root()
    from lkypanel.models import Website
    from lkypanel.services.ssl import request_certificate
    try:
        site = Website.objects.get(domain=args.domain)
    except Website.DoesNotExist:
        err(f'Website not found: {args.domain}')
        return
    info(f'Requesting SSL certificate for {args.domain}...')
    try:
        cert = request_certificate(site)
        ok(f'SSL certificate issued')
        info(f'Cert path:  {cert.cert_path}')
        info(f'Expires:    {cert.expires_at.strftime("%Y-%m-%d")}')
    except Exception as e:
        err(str(e))

def cmd_ssl_status(args):
    from lkypanel.models import Website
    try:
        site = Website.objects.get(domain=args.domain)
    except Website.DoesNotExist:
        err(f'Website not found: {args.domain}')
        return
    bold(f'SSL Status: {args.domain}')
    if not site.ssl_enabled:
        warn('SSL not enabled for this website.')
        return
    try:
        cert = site.ssl_certificate
        now = datetime.now(timezone.utc)
        days_left = (cert.expires_at - now).days
        colour = G if days_left > 30 else (Y if days_left > 7 else R)
        print(f'  Cert path:   {cert.cert_path}')
        print(f'  Issued:      {cert.issued_at.strftime("%Y-%m-%d")}')
        print(f'  Expires:     {cert.expires_at.strftime("%Y-%m-%d")} '
              f'({colour}{days_left} days{NC})')
        print(f'  Auto-renew:  {"yes" if cert.auto_renew else "no"}')
    except Exception:
        warn('No SSL certificate record found.')

def cmd_ssl_renew(args):
    _require_root()
    from lkypanel.models import Website
    from lkypanel.services.ssl import renew_certificate
    try:
        site = Website.objects.get(domain=args.domain)
        cert = site.ssl_certificate
    except Website.DoesNotExist:
        err(f'Website not found: {args.domain}')
        return
    except Exception:
        err(f'No SSL certificate found for {args.domain}')
        return
    info(f'Renewing SSL for {args.domain}...')
    try:
        renew_certificate(cert)
        ok(f'SSL renewed for {args.domain}')
    except Exception as e:
        err(str(e))

