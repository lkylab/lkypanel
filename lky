def cmd_user_list(args):
    from lkypanel.models import User
    users = User.objects.all().order_by('username')
    bold(f'Users ({users.count()})')
    print()
    table(
        ['ID', 'Username', 'Email', 'Role', 'Active', 'Created'],
        [(u.pk, u.username, u.email, u.role,
          'yes' if u.is_active else 'no',
          u.created_at.strftime('%Y-%m-%d')) for u in users]
    )

def cmd_user_create(args):
    _require_root()
    from lkypanel.models import User
    bold('Create User')
    username = input('  Username: ').strip()
    email    = input('  Email:    ').strip()
    role     = input('  Role [admin/user] (default: user): ').strip() or 'user'
    password = getpass.getpass('  Password: ')
    confirm  = getpass.getpass('  Confirm:  ')

    if password != confirm:
        err('Passwords do not match.')
        return
    if role not in ('admin', 'user'):
        err('Role must be admin or user.')
        return
    if User.objects.filter(username=username).exists():
        err(f'User "{username}" already exists.')
        return

    try:
        u = User.objects.create_user(username=username, email=email,
                                     password=password, role=role)
        ok(f'User created: {u.username} ({u.role})')
    except Exception as e:
        err(str(e))

def cmd_user_delete(args):
    _require_root()
    from lkypanel.models import User
    try:
        u = User.objects.get(username=args.username)
    except User.DoesNotExist:
        err(f'User not found: {args.username}')
        return
    confirm = input(f'  Delete user "{u.username}"? [y/N] ').strip().lower()
    if confirm != 'y':
        warn('Cancelled.')
