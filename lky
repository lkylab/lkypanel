def main():
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return

    subcommand = getattr(args, 'subcommand', None)
    key = (args.command, subcommand)

    handler = DISPATCH.get(key)
    if handler:
        handler(args)
    else:
        # Print subcommand help
        parser.parse_args([args.command, '--help'])

if __name__ == '__main__':
    main()
