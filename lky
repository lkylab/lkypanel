# ── check ─────────────────────────────────────────────────────────────────────
def cmd_check(args):
    venv_python = os.path.join(INSTALL_DIR, 'venv', 'bin', 'python')
    manage = os.path.join(INSTALL_DIR, 'manage.py')
    subprocess.run([venv_python, manage, 'check_requirements'])

# ── logs ──────────────────────────────────────────────────────────────────────
def cmd_logs(args):
    lines = getattr(args, 'lines', 50)
    log_file = '/var/log/lkypanel/panel.log'
    if not os.path.exists(log_file):
        err(f'Log file not found: {log_file}')
        return
    subprocess.run(['tail', f'-n{lines}', log_file])

