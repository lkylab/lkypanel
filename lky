"""
lky — Command line interface for LkyPanel
Usage: lky <command> [subcommand] [args]
"""

# ── Argument parser ───────────────────────────────────────────────────────────
def build_parser():
    p = argparse.ArgumentParser(
        prog='lky',
        description='LkyPanel — Lightweight Hosting Control Panel CLI',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  lky status
  lky website list
  lky website create
  lky website info example.com
  lky ssl request example.com
  lky git pull example.com
  lky db list example.com
  lky logs --lines 100
        """
    )
    sub = p.add_subparsers(dest='command', metavar='command')

    # ── top-level ──
    sub.add_parser('status',  help='Show service status')
    sub.add_parser('start',   help='Start panel services')
    sub.add_parser('stop',    help='Stop panel services')
    sub.add_parser('restart', help='Restart panel services')
    sub.add_parser('version', help='Show panel version')
    sub.add_parser('check',   help='Run system requirements check')

    logs_p = sub.add_parser('logs', help='Tail panel logs')
    logs_p.add_argument('--lines', '-n', type=int, default=50, metavar='N')

    # ── user ──
    u = sub.add_parser('user', help='User management')
    us = u.add_subparsers(dest='subcommand', metavar='subcommand')
    us.add_parser('list',   help='List all users')
    us.add_parser('create', help='Create a user (interactive)')
    ud = us.add_parser('delete', help='Delete a user')
    ud.add_argument('username')
    up = us.add_parser('passwd', help='Reset user password')
    up.add_argument('username')

    # ── website ──
    w = sub.add_parser('website', help='Website management')
    ws = w.add_subparsers(dest='subcommand', metavar='subcommand')
    ws.add_parser('list',   help='List all websites')
    ws.add_parser('create', help='Create a website (interactive)')
    wd = ws.add_parser('delete', help='Delete a website')
    wd.add_argument('domain')
    wi = ws.add_parser('info', help='Show website details')
    wi.add_argument('domain')

    # ── ftp ──
    f = sub.add_parser('ftp', help='FTP account management')
    fs = f.add_subparsers(dest='subcommand', metavar='subcommand')
    fl = fs.add_parser('list',    help='List FTP accounts')
    fl.add_argument('domain', nargs='?', default=None)
    fs.add_parser('create',  help='Create FTP account (interactive)')
    fs.add_parser('install', help='Install Pure-FTPd')
    fd = fs.add_parser('delete',  help='Delete FTP account')
    fd.add_argument('username')
    fp = fs.add_parser('passwd',  help='Change FTP password')
    fp.add_argument('username')

    # ── ssl ──
    s = sub.add_parser('ssl', help='SSL certificate management')
    ss = s.add_subparsers(dest='subcommand', metavar='subcommand')
    sr = ss.add_parser('request', help='Request Let\'s Encrypt SSL')
    sr.add_argument('domain')
    sst = ss.add_parser('status', help='Show SSL status')
    sst.add_argument('domain')
    srn = ss.add_parser('renew', help='Force SSL renewal')
    srn.add_argument('domain')

    # ── git ──
    g = sub.add_parser('git', help='Git repository management')
    gs = g.add_subparsers(dest='subcommand', metavar='subcommand')
    gst = gs.add_parser('status', help='Show linked Git repo')
    gst.add_argument('domain')
    gpl = gs.add_parser('pull', help='Git pull')
    gpl.add_argument('domain')
    gps = gs.add_parser('push', help='Git push')
    gps.add_argument('domain')

    # ── db ──
    d = sub.add_parser('db', help='Database management')
    ds = d.add_subparsers(dest='subcommand', metavar='subcommand')
    dl = ds.add_parser('list',   help='List databases')
    dl.add_argument('domain', nargs='?', default=None)
    ds.add_parser('create', help='Create database (interactive)')
    dd = ds.add_parser('delete', help='Delete database')
    dd.add_argument('db_name')

    # ── ols ──
    ol = sub.add_parser('ols', help='OpenLiteSpeed management')
    ols = ol.add_subparsers(dest='subcommand', metavar='subcommand')
    ols.add_parser('setup-panel', help='Refactor OLS to serve Panel ports')

    return p

