          s.created_at.strftime('%Y-%m-%d')) for s in sites]
    )

def cmd_website_create(args):
    _require_root()
    from lkypanel.models import Website, User
    from lkypanel.services.ols import create_docroot, write_vhost_config, reload_ols
    bold('Create Website')
    domain      = input('  Domain:      ').strip().lower()
    owner_name  = input('  Owner (username): ').strip()
    php_version = input('  PHP version [8.1]: ').strip() or '8.1'

    try:
        owner = User.objects.get(username=owner_name)
    except User.DoesNotExist:
        err(f'User not found: {owner_name}')
        return
    if Website.objects.filter(domain=domain).exists():
        err(f'Domain already exists: {domain}')
        return
    try:
        site = Website(owner=owner, domain=domain, php_version=php_version)
        site.full_clean()
        site.save()
        create_docroot(domain)
        write_vhost_config(domain, php_version)
        reload_ols()
        ok(f'Website created: {domain}')
        info(f'Doc root: {site.doc_root}')
    except Exception as e:
        err(str(e))

def cmd_website_delete(args):
    _require_root()
    from lkypanel.models import Website
    from lkypanel.services.ols import delete_vhost_config, reload_ols
    try:
        site = Website.objects.get(domain=args.domain)
    except Website.DoesNotExist:
        err(f'Website not found: {args.domain}')
        return
    confirm = input(f'  Delete website "{args.domain}"? [y/N] ').strip().lower()
    if confirm != 'y':
        warn('Cancelled.')
        return
    del_files = input('  Also delete website files? [y/N] ').strip().lower() == 'y'
    if del_files:
        import shutil, pathlib
        home = pathlib.Path(f'/home/{args.domain}')
        if home.exists():
            shutil.rmtree(str(home))
            info(f'Deleted files: {home}')
    delete_vhost_config(args.domain)
    site.delete()
    reload_ols()
    ok(f'Deleted website: {args.domain}')

